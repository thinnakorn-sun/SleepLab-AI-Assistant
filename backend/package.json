{
  "name": "line-chatbot-backend",
  "version": "1.0.0",
  "description": "LINE AI Chatbot RAG System",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "start": "nest start",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev:nest": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "index:pdf": "ts-node --project tsconfig.json scripts/indexing/index-pdf.ts --file knowledge-base.pdf",
    "index:txt": "ts-node --project tsconfig.json scripts/indexing/index-pdf.ts",
    "clear-test-data": "ts-node --project tsconfig.json scripts/db/clear-test-data.ts",
    "eval:rag": "ts-node --project tsconfig.json scripts/eval/eval-rag.ts",
    "verify:rag": "ts-node --project tsconfig.json scripts/eval/verify-rag.ts"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@line/bot-sdk": "^7.5.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.20.0",
    "pgvector": "^0.1.7",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.19.35",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
}
