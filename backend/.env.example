# ──────────────────────────────────────────────────────────
# LINE AI Chatbot - Environment Variables
# ──────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values below before starting the server.
# ──────────────────────────────────────────────────────────

# ── OpenAI (ถ้าใช้ Gemini ทั้งหมด ไม่ต้องใส่) ───────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o-mini

# ── Google Gemini (embedding + สร้างคำตอบ FAQ) ─────────────
GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash  # optional, default

# ── LINE (ห้าม hardcode ในโค้ด) ─────────────────────────────
# ได้จาก LINE Developers Console > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# default เมื่อไม่มี x-line-channel-id header (ใช้ LINE_OA_ID หรือ LINE_CHANNEL_ID)
LINE_OA_ID=default
# ชื่อศูนย์ fallback เมื่อไม่มี oa_settings ใน DB
DEFAULT_CENTER_NAME=

# ── LINE Multi OA (Single service, 6 accounts) ──────────────
# ใส่เพิ่มตามจำนวน OA ที่ใช้จริง (suffix ต้องตรงกันใน 3 ค่า)
# ตัวอย่าง KEY=OA2
# LINE_OA_ID_OA2=Your OA 2 Name
# LINE_CHANNEL_ACCESS_TOKEN_OA2=
# LINE_CHANNEL_SECRET_OA2=

# OA #2
LINE_OA_ID_OA2=
LINE_CHANNEL_ACCESS_TOKEN_OA2=
LINE_CHANNEL_SECRET_OA2=

# OA #3
LINE_OA_ID_OA3=
LINE_CHANNEL_ACCESS_TOKEN_OA3=
LINE_CHANNEL_SECRET_OA3=

# OA #4
LINE_OA_ID_OA4=
LINE_CHANNEL_ACCESS_TOKEN_OA4=
LINE_CHANNEL_SECRET_OA4=

# OA #5
LINE_OA_ID_OA5=
LINE_CHANNEL_ACCESS_TOKEN_OA5=
LINE_CHANNEL_SECRET_OA5=

# OA #6
LINE_OA_ID_OA6=
LINE_CHANNEL_ACCESS_TOKEN_OA6=
LINE_CHANNEL_SECRET_OA6=

# ช่วงทดสอบเท่านั้น: บอทตอบเฉพาะ userId ที่ใส่ (คั่นด้วย comma)
TEST_LINE_USER_IDS=

# ── Chatbot (ข้อความ, เวลาทำการ) ───────────────────────────
# BOT_NAME=MOONi
# BUSINESS_HOURS=จันทร์–ศุกร์ 08:00–17:00 น.
# CONTACT_MENU_KEY=E

# ── Gemini (optional) ─────────────────────────────────────
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG_DEBUG=true   # log chunks + distance ทุกครั้งที่ตอบ FAQ (ใช้เช็คความแม่นยำ)
RAG_DEBUG=false
FAQ_USE_FLEX=true

# ── Database (Neon PostgreSQL) ─────────────────────────────
# วิธีได้ DATABASE_URL:
# 1. ไปที่ https://console.neon.tech  → เลือก Project → Connection Details
# 2. เลือก mode = "Session" หรือ "Pooled" (แนะนำ Pooled สำหรับ Production)
# 3. Copy Connection String มาใส่ด้านล่าง
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require

# แยก field สำหรับ TypeORM (ถ้าไม่ใช้ DATABASE_URL)
DB_HOST=ep-XXXX.us-east-2.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=
DB_NAME=neondb
